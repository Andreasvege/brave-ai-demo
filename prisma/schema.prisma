generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// status er en av RECORDED | TRANSCRIBING | ANALYZING | DONE | FAILED, analysis er JSON-streng.
model Call {
  id          String   @id @default(cuid())
  title       String?
  status      String   @default("RECORDED")
  durationSec Int?
  notes       String?
  transcript  String?
  analysis    String?
  error       String?
  createdAt   DateTime @default(now())
}
